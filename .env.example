# Environment configuration for Open Source Contribution Tracker
# Copy this file to .env and fill in your values.
# Run: cp .env.example .env

# GitHub personal access token (required for higher rate limits: 5000 req/hr vs 60/hr)
# Create one at: https://github.com/settings/tokens
# Required scopes: public_repo (read-only is sufficient)
GITHUB_TOKEN=your_github_token_here

# Flask settings
FLASK_ENV=development
DEBUG=True

# SQLite database file location (relative to project root)
DATABASE_PATH=tracker.db

# Server
PORT=5000
